# Swoidrice Sway Configuration
# Based on dwm keybindings and LARBS philosophy

set $mod Mod4

# Use Wayland-native terminal (foot)
set $terminal foot
set $browser firefox
set $filemanager lf
set $launcher rofi -show drun -show-icons

# Output configuration
output * bg #282828 solid_color

# Font for window titles
font pango:JetBrains Mono, DejaVu Sans Mono 11

# Gaps
gaps inner 5
gaps outer 5

# Input configuration
input * {
    xkb_layout us
    xkb_options caps:escape
    repeat_rate 60
    repeat_delay 200
}

# Touchpad configuration
input "synaptics:*" {
    tap enabled
    natural_scroll enabled
}

input "elantech:*" {
    tap enabled
    natural_scroll enabled
}

# Status bar
bar {
    position top
    mode dock
    status_command waybar
}

# Preferences
floating_modifier $mod normal
titlebar_border_thickness 2
titlebar_border_inactive_color #444444
titlebar_border_focused_color #666666
titlebar_border_focused_inactive_color #444444
titlebar_border_urgent_color #ff0000

# Resize mode
mode "resize" {
    bindsym Left resize shrink width 10 px or 0.05
    bindsym Down resize grow height 10 px or 0.05
    bindsym Up resize shrink height 10 px or 0.05
    bindsym Right resize grow width 10 px or 0.05
    
    bindsym h resize shrink width 10 px or 0.05
    bindsym j resize grow height 10 px or 0.05
    bindsym k resize shrink height 10 px or 0.05
    bindsym l resize grow width 10 px or 0.05
    
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod mode "default"
}

# Keybindings - based on dwm
bindsym $mod+Return exec $terminal
bindsym $mod+d exec $launcher
bindsym $mod+j exec $terminal -e lf
bindsym $mod+w exec $browser
bindsym $mod+m exec mpc toggle

# Kill focused window
bindsym $mod+Shift+q kill

# Reload sway config
bindsym $mod+Shift+c reload

# Exit sway (logout)
bindsym $mod+Shift+e exit

# Change to workspace numbers
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

# Move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# Move focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Resize mode
bindsym $mod+r mode "resize"

# Split in horizontal orientation
bindsym $mod+Shift+h split h

# Split in vertical orientation
bindsym $mod+Shift+v split v

# Toggle fullscreen
bindsym $mod+f fullscreen toggle

# Layouts
bindsym $mod+b layout tabbed
bindsym $mod+Shift+b layout stacking
bindsym $mod+Shift+n layout normal

# Toggle scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Screenshot bindings
bindsym Print exec grim ~/Screenshots/$(date +%Y%m%d_%H%M%S).png
bindsym $mod+Print exec grim -g "$(slurp)" ~/Screenshots/$(date +%Y%m%d_%H%M%S).png

# Clipboard
bindsym $mod+c exec wl-copy $(swaymsg -t get_tree | jq -r '.. | .focused_window_id? // empty | if . then . else empty end | first')

# Brightness control
bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-

# Volume control
bindsym XF86AudioRaiseVolume exec pulsemixer --change-volume +5
bindsym XF86AudioLowerVolume exec pulsemixer --change-volume -5
bindsym XF86AudioMute exec pulsemixer --mute

# Application specific rules
for_window [app_id="firefox"] move scratchpad
for_window [title="Oracle VM VirtualBox Manager"] move position center
for_window [app_id="pavucontrol"] floating enable

# Startup applications
exec wpaperd
